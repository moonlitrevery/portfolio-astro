---
import BaseLayout from "../layouts/BaseLayout.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
import Certifications from "../components/Certifications.astro";
import Projects from "../components/Projects.astro";
import { experience, education, certifications, projects, techStack } from "../data/profile";
const base = import.meta.env.BASE_URL;
const socials = [
  { name: "GitHub", href: "https://github.com/moonlitrevery" },
  { name: "LinkedIn", href: "https://www.linkedin.com/in/joaobruschi/" },
];
const lang = Astro.url.searchParams.get('lang') === 'pt' ? 'pt' : 'en';
const dict = {
  en: {
    about: 'About',
    atAGlance: 'At a glance',
    roleReqs: 'Skills aligned to my roles',
    roleReqsDesc: 'From analytics and BI into production ML: engineering, experimentation, and business impact.',
    machineLearningEngineer: 'Machine Learning Engineer',
    dataScientist: 'Data Scientist',
    techStack: 'Tech Stack',
    projects: 'Projects',
    contact: 'Contact',
    heroDesc: 'Data Analyst & Data Scientist · Computer Science student @ UNISAGRADO · Specializing in Data Science and Cybersec Enthusiast',
    aboutDesc: "Hi, I'm João. I'm a professional Data Analyst & Data Scientist with interests spanning modern analytics, machine learning, and computational neuroscience. I enjoy turning data into decisions, building robust pipelines, and communicating insights clearly.",
    moreOnGitHub: 'More on GitHub:',
    visitProvider: 'Visit provider',
    view: 'View',
    nav: { about: 'About', requirements: 'Skills', projects: 'Projects', contact: 'Contact' },
    experience: 'Experience',
    education: 'Education',
    certifications: 'Certifications & Courses',
    openToOpportunities: 'Open to opportunities',
    downloadCV: 'Download CV',
    location: 'Bauru, Brazil',
    heroLabel: 'Introduction',
    aboutEyebrow: 'Background',
    stackEyebrow: 'Toolkit',
    glanceEyebrow: 'Snapshot',
    researchBand: 'Experience, education & certifications',
    bullets: {
      mle: [
        'Architected a churn stack as three decoupled Python surfaces: inference (FastAPI), batch training, and drift monitoring, so each layer can be tested, versioned, and owned on independent release cadences, mirroring production separation of concerns.',
        'Shipped a FastAPI scoring layer with Pydantic-validated I/O, explicit HTTP error semantics, and liveness/readiness endpoints sized for container rollouts and synchronous low-latency inference.',
        'Ran every training job through one reproducible pipeline that logs parameters, metrics, and serialized artifacts to MLflow, making parallel hyperparameter and architecture trials diffable and promotion decisions auditable.',
        'Instrumented serving-time drift: live feature distributions vs. a frozen reference window with thresholded alerts, catching covariate shift before lagging label-based metrics surface regressions.',
        'Retired notebook only retrains with scripted train → evaluate → artifact export, pinned dependencies, and fixed directory contracts, repeatable enough to wire into CI and staged releases instead of copy-paste runs.'
      ],
      dataScientist: [
        'Converted Power BI KPIs and stakeholder narratives into crisp ML problem statements: primary metric, guardrails, business baseline, and definition of “churn,” before writing model code.',
        'Engineered leakage-aware features with time-respecting train/validation splits on customer histories, optimizing precision/recall trade-offs for retention interventions rather than leaderboard accuracy.',
        'Built training tables end-to-end in SQL/ETL: correct grain, join keys, and snapshot timestamps so offline datasets mirror what production joins would see, eliminating train/serve skew at the source.',
        'Drove model selection with a written comparison matrix (baseline vs. tuned candidates), pairing ROC and PR and calibration plots with latency, complexity, and maintenance cost for each finalist.',
        'Briefed technical and business partners on what the model optimizes, failure modes, score band actions, and which monitoring signals fire first, linking model output to decisions, not slide decks.'
      ]
    }
  },
  pt: {
    about: 'Sobre',
    atAGlance: 'Em resumo',
    roleReqs: 'Competências alinhadas aos meus papéis',
    roleReqsDesc: 'Da análise e BI ao ML em produção: engenharia, experimentação e impacto de negócio.',
    machineLearningEngineer: 'Engenheiro de Machine Learning',
    dataScientist: 'Cientista de Dados',
    techStack: 'Tecnologias',
    projects: 'Projetos',
    contact: 'Contato',
    heroDesc: 'Analista e Cientista de Dados · Estudante de Ciência da Computação @ UNISAGRADO · Especialização em Ciência de Dados e Entusiasta de Cibersegurança',
    aboutDesc: 'Olá, eu sou o João. Sou Analista e Cientista de Dados com interesses em analytics moderno, machine learning e neurociência computacional. Gosto de transformar dados em decisões, construir pipelines robustos e comunicar insights com clareza.',
    moreOnGitHub: 'Mais no GitHub:',
    visitProvider: 'Visitar provedor',
    view: 'Ver',
    nav: { about: 'Sobre', requirements: 'Competências', projects: 'Projetos', contact: 'Contato' },
    experience: 'Experiência',
    education: 'Formação',
    certifications: 'Certificações e Cursos',
    openToOpportunities: 'Aberto a oportunidades',
    downloadCV: 'Baixar CV',
    location: 'Bauru, Brasil',
    heroLabel: 'Introdução',
    aboutEyebrow: 'Trajetória',
    stackEyebrow: 'Ferramentas',
    glanceEyebrow: 'Resumo',
    researchBand: 'Experiência, formação e certificações',
    bullets: {
      mle: [
        'Arquitetei o churn em três superfícies Python desacopladas: inferência (FastAPI), treino batch e monitoramento de drift, cada uma testável, versionável e com fronteira de responsabilidade clara, no padrão de serviços em produção.',
        'Entreguei camada de scoring em FastAPI com I/O validado em Pydantic, erros HTTP explícitos e endpoints de liveness/readiness, pensada para deploy em contêiner e inferência síncrona de baixa latência.',
        'Centralizei o treino em um pipeline reprodutível que registra parâmetros, métricas e artefatos serializados no MLflow, permitindo comparar múltiplas tentativas de hiperparâmetro/arquitetura com linhagem auditável para promoção de modelo.',
        'Instrumentei drift em serving: distribuições de features ao vivo vs. janela de referência congelada, com alertas por limiar, detectando covariate shift antes que métricas com label atrasado mostrem regressão.',
        'Substituí retrains só em notebook por script train → evaluate → export de artefatos, dependências fixadas e layout de diretórios contratual, execução repetível para CI e releases por estágios, não cópia manual.'
      ],
      dataScientist: [
        'Converti KPIs do Power BI e requisitos de negócio em definição formal do problema de ML: métrica primária, guardrails, baseline de negócio e definição operacional de churn, antes de codar o modelo.',
        'Construí features com consciência de vazamento e splits treino/validação que respeitam o tempo no histórico de clientes, priorizando trade-off precisão/recall para intervenções de retenção em vez de acurácia de leaderboard.',
        'Montei tabelas de treino ponta a ponta em SQL/ETL: grão correto, chaves de join e timestamps de snapshot para que o offline espelhe o que produção enxergaria, eliminando train/serve skew na origem.',
        'Conduzi escolha de modelo com matriz escrita baseline vs. candidatos afinados, com curvas de ROC e PR e calibração lado a lado com latência, complexidade e custo de manutenção por finalista.',
        'Apresentei para times técnicos e de negócio o que o modelo otimiza, modos de falha, faixas de score → ação e quais sinais de monitoramento disparam primeiro, ligando output do modelo a decisão operacional, não só slides.'
      ]
    }
  }
} as const;
const t = (k) => dict[lang][k];
---
<BaseLayout lang={lang} navLabels={{ about: t('nav').about, requirements: t('nav').requirements, projects: t('nav').projects, contact: t('nav').contact }}>
  <!-- Hero: light canvas + pastel atmosphere (decorative gradients only) -->
  <section class="animate-fade-in relative overflow-hidden rounded-comfy border border-black/[0.08] dark:border-white/[0.12]">
    <div class="hero-atmosphere" aria-hidden="true"></div>
    <div class="relative z-10 grid items-center gap-8 p-6 md:grid-cols-3 md:gap-10 md:p-10">
      <div class="md:col-span-2">
        <p class="section-label mb-3 text-black/50 dark:text-white/45">{t('heroLabel')}</p>
        <p class="body-large mb-2 text-black/70 dark:text-white/70">
          {lang === 'pt' ? 'Olá, eu sou' : 'Hello, I am'}
        </p>
        <h1 class="font-display text-[clamp(1.75rem,6vw,4rem)] font-medium leading-[1.1] tracking-[-0.04em] text-black dark:text-white md:tracking-[-1.92px]">
          João Vitor Bruschi
        </h1>
        <p class="body-large mt-5 max-w-2xl text-black/85 dark:text-white/85">
          {t('heroDesc')}
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <span class="badge inline-flex items-center gap-2 !py-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-3.5 w-3.5 text-lavender" fill="currentColor" aria-hidden="true"><path d="M12 2l3 7h7l-5.5 4.2L18 21l-6-3.8L6 21l1.5-7.8L2 9h7z"/></svg>
            {t('openToOpportunities')}
          </span>
          <a href={`${base}cv.pdf`} class="btn-primary" target="_blank" rel="noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm1 7H8V7h7v2z"/></svg>
            {t('downloadCV')}
          </a>
          {socials.map((s) => (
            <a href={s.href} class="btn-outline" target="_blank" rel="noreferrer">{s.name}</a>
          ))}
        </div>
      </div>
      <div class="justify-self-center md:justify-self-end">
        <div class="relative">
          <div class="absolute -inset-2 rounded-comfy bg-gradient-to-br from-lavender/30 via-transparent to-brand-orange/10 blur-xl dark:from-lavender/10 dark:to-brand-magenta/5" aria-hidden="true"></div>
          <img
            src={`${base}me.jpg`}
            alt="João Vitor portrait"
            class="relative h-40 w-40 rounded-comfy border border-black/[0.08] object-cover shadow-elevate dark:border-white/[0.12] md:h-52 md:w-52"
          />
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="mt-20 grid gap-8 md:mt-28 md:grid-cols-3 md:gap-10">
    <div class="md:col-span-2">
      <p class="section-label mb-3 text-black/50 dark:text-white/45">{t('aboutEyebrow')}</p>
      <h2 class="heading-section font-display text-black dark:text-white">{t('about')}</h2>
      <p class="body-large mt-4 text-black/85 dark:text-white/85">
        {t('aboutDesc')}
      </p>
      <div class="mt-10">
        <p class="section-label mb-3 text-black/50 dark:text-white/45">{t('stackEyebrow')}</p>
        <h3 class="heading-sub font-display text-black dark:text-white">{t('techStack')}</h3>
        <ul class="mt-4 flex flex-wrap gap-2">
          {techStack.map((tech) => <li class="badge">{tech}</li>)}
        </ul>
      </div>
    </div>
    <aside class="card h-fit">
      <p class="section-label mb-3 text-black/50 dark:text-white/45">{t('glanceEyebrow')}</p>
      <h3 class="heading-sub font-display text-black dark:text-white">{t('atAGlance')}</h3>
      <ul class="mt-4 space-y-3 caption text-black/80 dark:text-white/80">
        <li class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-lavender" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
          {t('location')}
        </li>
        <li class="flex items-center gap-2">
          <img src={`${base}icons/github.png`} alt="" class="h-4 w-4 shrink-0" width="16" height="16" />
          <span>GitHub: <a class="underline decoration-black/20 underline-offset-2 transition-colors hover:text-lavender dark:decoration-white/30" href="https://github.com/moonlitrevery" target="_blank" rel="noreferrer">@moonlitrevery</a></span>
        </li>
        <li class="flex items-center gap-2">
          <img src={`${base}icons/linkedin.png`} alt="" class="h-4 w-4 shrink-0" width="16" height="16" />
          <span>LinkedIn: <a class="underline decoration-black/20 underline-offset-2 transition-colors hover:text-lavender dark:decoration-white/30" href="https://www.linkedin.com/in/joaobruschi/" target="_blank" rel="noreferrer">joaobruschi</a></span>
        </li>
      </ul>
    </aside>
  </section>

  <section id="requirements" class="mt-20 md:mt-28">
    <p class="section-label mb-3 text-black/50 dark:text-white/45">{t('nav').requirements}</p>
    <h2 class="heading-section font-display text-black dark:text-white">{t('roleReqs')}</h2>
    <p class="body-large mt-4 max-w-3xl text-black/75 dark:text-white/75">{t('roleReqsDesc')}</p>

    <div class="mt-10 grid gap-10 md:grid-cols-2 md:gap-12">
      <div>
        <h3 class="heading-sub font-display text-black dark:text-white">{t('machineLearningEngineer')}</h3>
        <ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-relaxed text-black/90 dark:text-white/90" style="letter-spacing: -0.16px;">
          {t('bullets').mle.map((b: string) => <li>{b}</li>)}
        </ul>
      </div>
      <div>
        <h3 class="heading-sub font-display text-black dark:text-white">{t('dataScientist')}</h3>
        <ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-relaxed text-black/90 dark:text-white/90" style="letter-spacing: -0.16px;">
          {t('bullets').dataScientist.map((b: string) => <li>{b}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- Dark band: midnight blue research zone per DESIGN.md -->
  <div class="relative left-1/2 my-20 w-screen -translate-x-1/2 bg-midnight px-4 py-20 text-white md:my-28 md:px-8 md:py-28">
    <div class="mx-auto max-w-content">
      <p class="section-label mb-12 text-white/45">{t('researchBand')}</p>
      <Experience items={experience} lang={lang} title={t('experience')} variant="dark" />
      <Education items={education} lang={lang} title={t('education')} variant="dark" />
      <Certifications items={certifications} visitLabel={t('visitProvider')} title={t('certifications')} variant="dark" />
    </div>
  </div>

  <Projects items={projects} viewLabel={t('view')} title={t('projects')} moreOnGitHub={t('moreOnGitHub')} lang={lang} />

  <div class="my-20 h-px w-full bg-black/[0.08] dark:bg-white/[0.12] md:my-28"></div>

  <section id="contact" class="pb-8 md:pb-12">
    <p class="section-label mb-3 text-black/50 dark:text-white/45">{t('contact')}</p>
    <h2 class="heading-section font-display text-black dark:text-white">{t('contact')}</h2>
    <p class="body-large mt-4 max-w-2xl text-black/75 dark:text-white/75">
      {lang === 'pt'
        ? 'Estou sempre aberto a novas oportunidades e colaborações. Entre em contato comigo através dos canais abaixo:'
        : "I'm always open to new opportunities and collaborations. Get in touch with me through the channels below:"}
    </p>
    <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <a class="card flex flex-col items-center p-6 text-center transition-transform duration-200 hover:-translate-y-0.5" href="https://www.linkedin.com/in/joaobruschi/" target="_blank" rel="noreferrer">
        <img src={`${base}icons/linkedin.png`} alt="" class="mb-3 h-8 w-8" width="32" height="32" />
        <span class="body-default font-medium text-black dark:text-white">LinkedIn</span>
        <span class="caption mt-1 text-black/55 dark:text-white/50">Professional Network</span>
      </a>
      <a class="card flex flex-col items-center p-6 text-center transition-transform duration-200 hover:-translate-y-0.5" href="https://github.com/moonlitrevery" target="_blank" rel="noreferrer">
        <img src={`${base}icons/github.png`} alt="" class="mb-3 h-8 w-8" width="32" height="32" />
        <span class="body-default font-medium text-black dark:text-white">GitHub</span>
        <span class="caption mt-1 text-black/55 dark:text-white/50">Code & Projects</span>
      </a>
      <a class="card flex flex-col items-center p-6 text-center transition-transform duration-200 hover:-translate-y-0.5" href="mailto:joao.bruschi@outlook.com.br">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="mb-3 h-8 w-8 text-lavender" fill="currentColor" aria-hidden="true"><path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        <span class="body-default font-medium text-black dark:text-white">Email</span>
        <span class="caption mt-1 text-black/55 dark:text-white/50">joao.bruschi@outlook.com.br</span>
      </a>
    </div>
  </section>
</BaseLayout>
