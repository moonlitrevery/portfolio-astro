---
import type { ExperienceItem } from "../data/profile";
export interface Props { items: ExperienceItem[]; title?: string; variant?: 'light' | 'dark' }
const { items, title = 'Experience', variant = 'light' } = Astro.props as Props;
const isDark = variant === 'dark';
---
<section id="experience" class:list={[isDark ? 'mt-0' : 'mt-20 md:mt-28']}>
  <h2 class:list={['heading-section font-display', isDark ? 'text-white' : 'text-black dark:text-white']}>
    {title}
  </h2>
  <div class="mt-8 space-y-8">
    {items.map((job) => (
      <article class:list={[isDark ? 'card-research' : 'card']}>
        <header>
          <h3 class:list={['text-[1.375rem] font-medium leading-tight font-display', isDark ? 'text-white' : 'text-black dark:text-white']} style="letter-spacing: -0.22px;">
            {job.title}
          </h3>
          {job.period && (
            <p
              class:list={[
                'mt-0.5 text-xs leading-snug font-normal',
                isDark ? 'text-white/45' : 'text-black/45 dark:text-white/45',
              ]}
            >
              {job.period}
            </p>
          )}
          <p class:list={['mt-1 caption', isDark ? 'text-white/60' : 'text-black/60 dark:text-white/60']}>{job.company}</p>
        </header>
        <ul class:list={['mt-4 list-disc space-y-2 pl-5 text-sm leading-relaxed', isDark ? 'text-white/90' : 'text-black/90 dark:text-white/90']} style="letter-spacing: -0.16px;">
          {job.bullets.map((b) => <li>{b}</li>)}
        </ul>
      </article>
    ))}
  </div>
</section>
