---
import type { ProjectItem } from "../data/profile";
export interface Props { items: ProjectItem[]; viewLabel?: string; title?: string; moreOnGitHub?: string }
const { items, viewLabel = 'View', title = 'Projects', moreOnGitHub = 'More on GitHub:' } = Astro.props as Props;
---
<section id="projects" class="mt-20 md:mt-28">
  <h2 class="heading-section font-display text-black dark:text-white">{title}</h2>
  <div class="mt-8 grid gap-6 md:grid-cols-2">
    {items.map((p) => (
      <article class="card transition-transform duration-200 hover:-translate-y-0.5">
        <header class="flex items-center justify-between gap-3">
          <h3 class="text-[1.375rem] font-medium leading-tight text-black dark:text-white font-display" style="letter-spacing: -0.22px;">{p.displayName}</h3>
          <a class="btn-primary flex-shrink-0 !py-1.5 !px-3 text-sm" href={p.url} target="_blank" rel="noreferrer">{viewLabel}</a>
        </header>
        {p.description && (
          <p class="body-default mt-3 text-black/85 dark:text-white/85">
            {p.description}
          </p>
        )}
        {p.tech && p.tech.length > 0 && (
          <ul class="mt-4 flex flex-wrap gap-2">
            {p.tech.map((t) => <li class="badge">{t}</li>)}
          </ul>
        )}
      </article>
    ))}
  </div>
  <p class="caption mt-6 text-black/55 dark:text-white/55">
    {moreOnGitHub}{' '}
    <a class="underline decoration-black/20 underline-offset-2 transition-colors hover:text-lavender dark:decoration-white/30" href="https://github.com/moonlitrevery" target="_blank" rel="noreferrer">@moonlitrevery</a>
  </p>
</section>
